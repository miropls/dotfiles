" ── Options ───────────────────────────────────────────────────────────────
let mapleader = " "

set VimEverywhere
set ideaput
set ideajoin

set number
set relativenumber
set ignorecase
set smartcase
set incsearch
set nohlsearch
set scrolloff=8
set noshowmode
set clipboard+=ideaput

" ── Plugins ──────────────────────────────────────────────────────────────
" Ensure these are correctly toggled
set surround
set commentary
set sneak
set exchange
set argtextobj
set highlightedyank
set matchit
set NERDTree

" ── Search centered ──────────────────────────────────────────────────────
nnoremap n nzzzv
nnoremap N Nzzzv

" ── Clipboard ────────────────────────────────────────────────────────────
" Using standard vim mappings for system clipboard
nnoremap <leader>y "+y
vnoremap <leader>y "+y
nnoremap <leader>Y "+Y

" ── IDE Actions (Keep these as nmap, NOT nnoremap) ───────────────────────
nmap gh <Action>(ShowHoverInfo)
nmap gl <Action>(ShowErrorDescription)
nmap gd <Action>(GotoDeclaration)
nmap gD <Action>(GotoDeclaration)
nmap gt <Action>(GotoTypeDeclaration)
nmap gr <Action>(FindUsages)
nmap gi <Action>(GotoImplementation)
nmap ga <Action>(ShowIntentionActions)
nmap <leader>rn <Action>(RenameElement)
nmap <leader>ff <Action>(SearchEverywhere)

" ── Tabs / Panes ─────────────────────────────────────────────────────────
nmap <leader>cr <Action>(CloseAllToTheRight)
nmap <leader>cl <Action>(CloseAllToTheLeft)
nmap <leader>ca <Action>(CloseAllEditors)