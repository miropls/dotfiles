{
  // ── Appearance ───────────────────────────────────────────────────────────
  "completion_menu_item_kind": "symbol",
  "outline_panel": {
    "dock": "right",
  },
  "collaboration_panel": {
    "dock": "right",
  },
  "git_panel": {
    "dock": "right",
  },
  "soft_wrap": "editor_width",
  "toolbar": {
    "code_actions": true,
    "agent_review": true,
    "selections_menu": true,
    "quick_actions": false,
    "breadcrumbs": false,
  },
  "theme": {
    "mode": "system",
    "light": "Dawnfox - blurred",
    "dark": "Catppuccin Espresso (Blur) [Light]",
  },
  "icon_theme": {
    "mode": "system",
    "light": "Catppuccin Latte",
    "dark": "Catppuccin Mocha",
  },
  "ui_font_family": "Terminess Nerd Font Mono",
  "ui_font_weight": 500,
  "ui_font_size": 16.0,
  "buffer_font_family": "Terminess Nerd Font Mono",
  "buffer_font_size": 17.0,
  "buffer_line_height": "standard",
  "buffer_font_weight": 500,
  "cursor_shape": "block",
  "title_bar": { "show_branch_status_icon": true, "show_sign_in": false },
  "tab_bar": {
    "show": true,
    "show_nav_history_buttons": false,
    "show_pinned_tabs_in_separate_row": true,
  },
  "project_panel": { "dock": "right", "entry_spacing": "standard" },
  "when_closing_with_no_tabs": "keep_window_open",

  // ── Editor ───────────────────────────────────────────────────────────────
  "format_on_save": "on",
  "autosave": "off",
  "inlay_hints": { "enabled": false },
  "code_lens": "on",

  // ── Vim ──────────────────────────────────────────────────────────────────
  "vim_mode": true,
  "vim": {
    "toggle_relative_line_numbers": true,
    "use_system_clipboard": "always",
    "use_smartcase_find": true,
  },

  // ── Agent / AI ───────────────────────────────────────────────────────────
  "agent": {
    "play_sound_when_agent_done": "when_hidden",
    "sidebar_side": "left",
    "thinking_display": "preview",
    "default_model": {
      "effort": "high",
      "provider": "copilot_chat",
      "model": "claude-sonnet-4.6",
      "enable_thinking": true,
    },
    "show_turn_stats": true,
    "dock": "left",
    "default_profile": "write",
    "enable_feedback": false,
    "tool_permissions": { "default": "allow" },
    "inline_assistant_model": {
      "provider": "copilot_chat",
      "model": "claude-haiku-4.5",
    },
  },
  "agent_ui_font_size": 16,
  "agent_buffer_font_size": 15,
  "edit_predictions": {
    "mode": "subtle",
    "codestral": {
      "model": "codestral-latest",
    },
    "provider": "codestral",
  },

  // ── Misc ─────────────────────────────────────────────────────────────────
  "which_key": { "enabled": true, "delay_ms": 400 },
  "telemetry": { "diagnostics": false, "metrics": false },
  "auto_install_extensions": {
    "kanagawa-themes": true,
    "catppuccin-icons": true,
    "react-typescript-snippets": true,
  },
}
